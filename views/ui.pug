doctype html
html(lang="zh")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= title
    style.
      :root {
        color-scheme: dark;
        --bg: #0b1020;
        --bg-soft: #11192c;
        --panel: #121a2e;
        --panel-2: #17223a;
        --card: #1a2742;
        --card-2: #203152;
        --text: #ecf2ff;
        --muted: #9fb0d1;
        --border: #2a3a5d;
        --border-strong: #3f5684;
        --accent: #6ba7ff;
        --accent-2: #78e0c1;
        --danger: #ff8664;
        --shadow: rgba(0, 0, 0, 0.28);
        --radius: 18px;
        --radius-sm: 12px;
        --gap: 14px;
        --pad: 16px;
        --mono: ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", monospace;
        --font: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      * { box-sizing: border-box; }
      html, body { min-height: 100%; }
      body {
        margin: 0;
        color: var(--text);
        font-family: var(--font);
        background:
          radial-gradient(circle at 15% 10%, rgba(107, 167, 255, 0.18), transparent 28%),
          radial-gradient(circle at 85% 15%, rgba(120, 224, 193, 0.14), transparent 22%),
          radial-gradient(circle at 50% 90%, rgba(107, 167, 255, 0.08), transparent 30%),
          var(--bg);
      }

      button, input, select, textarea { font: inherit; }
      button {
        cursor: pointer;
        border: 0;
      }
      input, select, textarea {
        width: 100%;
        border: 1px solid var(--border);
        background: var(--bg-soft);
        color: var(--text);
        border-radius: 10px;
        outline: none;
      }
      input:focus, select:focus, textarea:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(107, 167, 255, 0.15);
      }

      .app-shell {
        min-height: 100vh;
        padding: 12px;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 8px 12px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: color-mix(in srgb, var(--panel) 90%, transparent);
        box-shadow: 0 14px 36px rgba(0, 0, 0, 0.18);
        backdrop-filter: blur(14px);
      }

      .brand h1 {
        margin: 0;
        font-size: 16px;
        line-height: 1.2;
      }

      .brand p {
        margin: 4px 0 0;
        color: var(--muted);
        font-size: 12px;
      }

      .toolbar {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 6px;
      }

      .chip-btn,
      .primary-btn,
      .ghost-btn {
        min-height: 32px;
        padding: 0 12px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: transform 0.12s ease, border-color 0.12s ease, background 0.12s ease;
      }

      .chip-btn:hover,
      .primary-btn:hover,
      .ghost-btn:hover {
        transform: translateY(-1px);
      }

      .ghost-btn {
        border: 1px solid var(--border);
        background: var(--card);
        color: var(--text);
      }

      .chip-btn {
        border: 1px solid var(--border);
        background: var(--card);
        color: var(--muted);
      }

      .primary-btn {
        border: 1px solid transparent;
        color: #fff;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        box-shadow: 0 14px 26px rgba(107, 167, 255, 0.18);
      }

      .layout {
        flex: 1;
        min-height: 0;
        display: grid;
        grid-template-columns: minmax(400px, 520px) minmax(0, 1fr);
        gap: 8px;
      }

      .panel,
      .preview {
        min-height: 0;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: color-mix(in srgb, var(--panel) 94%, transparent);
        box-shadow: 0 14px 36px rgba(0, 0, 0, 0.16);
        overflow: hidden;
      }

      .panel {
        display: flex;
        flex-direction: column;
      }

      .panel-scroll {
        flex: 1;
        min-height: 0;
        overflow: auto;
        padding: 10px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
        align-content: start;
      }

      .section {
        padding: 8px;
        background: color-mix(in srgb, var(--panel-2) 88%, transparent);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 0;
      }

      .section.full { grid-column: 1 / -1; }

      .section-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        font-size: 12px;
        color: var(--muted);
        letter-spacing: 0.02em;
      }

      .section-title strong {
        font-size: 12px;
        letter-spacing: 0;
        text-transform: none;
        color: var(--text);
      }

      .field {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .field-label,
      .inline-label {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        color: var(--muted);
        font-size: 12px;
      }

      .field-label .value {
        color: var(--accent);
        font-family: var(--mono);
        font-size: 11px;
      }

      .grid-2 {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
      }

      .shape-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 6px;
      }

      .preset-row {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }

      .preset-chip {
        min-height: 28px;
        padding: 0 10px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--card);
        color: var(--text);
        font-size: 12px;
        line-height: 1;
      }

      .preset-chip.active {
        border-color: var(--accent);
        background: color-mix(in srgb, var(--accent) 12%, var(--card));
        color: var(--accent-2);
      }

      .shape-card {
        min-height: 60px;
        padding: 6px 4px;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: var(--card);
        color: var(--muted);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        transition: transform 0.12s ease, border-color 0.12s ease, background 0.12s ease, color 0.12s ease;
      }

      .shape-card:hover {
        transform: translateY(-1px);
        border-color: var(--border-strong);
      }

      .shape-card.active {
        border-color: var(--accent);
        background: color-mix(in srgb, var(--accent) 12%, var(--card));
        color: var(--text);
      }

      .shape-card svg {
        width: 26px;
        height: 26px;
        overflow: visible;
      }

      .shape-card path,
      .shape-card circle,
      .shape-card rect,
      .shape-card polygon {
        fill: color-mix(in srgb, var(--panel) 88%, white);
        stroke: currentColor;
        stroke-width: 1.6;
        vector-effect: non-scaling-stroke;
      }

      .upload-zone {
        position: relative;
        min-height: 104px;
        border-radius: 12px;
        border: 1.5px dashed var(--border-strong);
        background: var(--card);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 14px;
        overflow: hidden;
      }

      .upload-zone.drag {
        border-color: var(--accent);
        background: color-mix(in srgb, var(--accent) 10%, var(--card));
      }

      .upload-zone input[type="file"] {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
      }

      .upload-zone .hint {
        pointer-events: none;
        display: flex;
        flex-direction: column;
        gap: 6px;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.4;
      }

      .upload-zone .hint strong {
        color: var(--text);
        font-size: 13px;
      }

      .file-line {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--accent-2);
        word-break: break-all;
      }

      .range-row {
        display: grid;
        grid-template-columns: 1fr 72px;
        gap: 10px;
        align-items: center;
      }

      input[type="range"] {
        appearance: none;
        height: 4px;
        border: 0;
        border-radius: 999px;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
      }

      input[type="range"]::-webkit-slider-thumb {
        appearance: none;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: var(--bg);
        border: 2px solid var(--accent);
        box-shadow: 0 0 0 4px rgba(107, 167, 255, 0.14);
      }

      input[type="color"] {
        width: 46px;
        height: 32px;
        padding: 0;
        border-radius: 8px;
        overflow: hidden;
      }

      .color-row {
        display: grid;
        grid-template-columns: 46px 1fr 86px;
        gap: 10px;
        align-items: center;
      }

      .toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
      }

      .switch {
        width: 44px;
        height: 24px;
        border-radius: 999px;
        background: var(--border);
        position: relative;
        cursor: pointer;
        flex: 0 0 auto;
        transition: background 0.12s ease;
      }

      .switch::after {
        content: "";
        position: absolute;
        top: 3px;
        left: 3px;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: #fff;
        transition: left 0.12s ease;
      }

      .switch.on {
        background: var(--accent);
      }

      .switch.on::after {
        left: 22px;
      }

      .stack {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .source-card {
        position: relative;
      }

      .source-card.drag {
        border-color: var(--accent);
        background: color-mix(in srgb, var(--accent) 8%, var(--panel-2));
        box-shadow: 0 0 0 1px rgba(107, 167, 255, 0.28);
      }

      .source-card.disabled {
        opacity: 0.62;
      }

      .source-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
      }

      .source-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }

      .source-mode {
        width: 96px;
      }

      .source-upload-btn {
        min-height: 32px;
        padding: 0 10px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--card);
        color: var(--text);
        display: inline-flex;
        align-items: center;
        gap: 6px;
        user-select: none;
      }

      .source-upload-btn input {
        display: none;
      }

      .source-upload-btn.disabled {
        opacity: 0.45;
        pointer-events: none;
      }

      .source-preview-row {
        display: grid;
        grid-template-columns: 72px minmax(0, 1fr);
        gap: 10px;
        align-items: center;
      }

      .source-preview {
        width: 72px;
        height: 72px;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: color-mix(in srgb, var(--panel) 88%, black);
        object-fit: contain;
        display: none;
      }

      .source-preview.visible {
        display: block;
      }

      .source-meta {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
      }

      .source-file-line {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--accent-2);
        word-break: break-all;
      }

      .source-hint {
        font-size: 11px;
        color: var(--muted);
        line-height: 1.4;
      }

      .request-box {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .request-box textarea {
        min-height: 112px;
        resize: vertical;
        padding: 10px;
        font-family: var(--mono);
        font-size: 11px;
        line-height: 1.5;
      }

      .request-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .preview {
        display: flex;
        flex-direction: column;
      }

      .preview-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 8px 10px;
        border-bottom: 1px solid var(--border);
        background: color-mix(in srgb, var(--panel-2) 75%, transparent);
      }

      .preview-head h2 {
        margin: 0;
        font-size: 14px;
      }

      .preview-meta {
        color: var(--muted);
        font-size: 12px;
      }

      .preview-body {
        flex: 1;
        min-height: 0;
        padding: 10px;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .preview-stage {
        flex: 1;
        min-height: 340px;
        border-radius: 20px;
        border: 1px solid var(--border);
        background:
          radial-gradient(circle at 20% 20%, rgba(107, 167, 255, 0.06), transparent 28%),
          radial-gradient(circle at 80% 80%, rgba(120, 224, 193, 0.06), transparent 26%),
          #0f1422;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
      }

      .preview-stage::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(45deg, rgba(255,255,255,0.03) 25%, transparent 25%) 0 0 / 22px 22px,
          linear-gradient(-45deg, rgba(255,255,255,0.03) 25%, transparent 25%) 0 11px / 22px 22px;
        opacity: 0.14;
        pointer-events: none;
      }

      #previewImage {
        position: relative;
        z-index: 1;
        max-width: 92%;
        max-height: 92%;
        display: block;
        user-select: none;
      }

      .preview-status {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        color: var(--muted);
        font-size: 12px;
      }

      .preview-status strong {
        color: var(--text);
      }

      .inline-note {
        font-size: 11px;
        color: var(--muted);
        line-height: 1.4;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      @media (max-width: 1100px) {
        .layout {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 760px) {
        .app-shell { padding: 10px; }
        .topbar {
          flex-direction: column;
          align-items: stretch;
        }
        .toolbar {
          justify-content: flex-start;
        }
        .panel-scroll {
          grid-template-columns: 1fr;
        }
        .section.full { grid-column: auto; }
        .grid-2,
        .color-row {
          grid-template-columns: 1fr;
        }
        .shape-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .preview-stage {
          min-height: 280px;
        }
      }
      body
    .app-shell
      header.topbar
        .brand
          h1 图标合成工作台
          p 直接调用 `server.js` 预览、复制请求并导出 PNG。
        .toolbar
          button#copyRequestBtn.chip-btn(type="button") 复制请求
          button#copyQueryBtn.ghost-btn(type="button") 复制查询串
          a.primary-btn(href="/icon?shape=pin&iconSize=128", target="_blank", rel="noreferrer") 打开示例图

      main.layout
        section.panel
          .panel-scroll
            section.section.full.source-card#imageSourceCard
              .section-title
                strong 图片来源
                span `GET / POST`
              .stack
                .source-head
                  .source-actions
                    .field-label
                      span 输入模式
                      span.value#modeState GET
                    select#imageModeSelect.source-mode
                      option(value="get", selected=true) GET
                      option(value="post") POST
                  label#imageUploadButton.source-upload-btn(for="imageUpload")
                    input#imageUpload(type="file", accept="image/*")
                    span 选择文件
                .source-preview-row
                  img#sourcePreview.source-preview(alt="文件预览")
                  .source-meta
                    span.source-file-line#fileName 未选择文件
                    span.source-hint#uploadHint 当前可输入 URL / 相对路径；如启用 `IMAGE_ENABLE_BASE64`，也可以用文件转成 `data:`。
                .field
                  .field-label
                    span 图片输入
                    span.value#imageState -
                  input#image(type="text", placeholder="https://example.com/icon.png / /assets/icon.png / data:image/png;base64,...", value=state.image || "")
                .field
                  .field-label
                    span 请求方式
                    span.value#requestMode GET
                  input#requestModeInput(type="text", readonly, value="GET /icon")
                .inline-note#imageNote
                  | `GET` 模式使用 `image` 文本；`POST` 模式优先使用文件上传。拖放整个卡片也会触发文件选择。

            section.section
              .section-title
                strong 形状
                span 选择外形
              .shape-grid#shapeGrid
                each shape in shapeOptions
                  button.shape-card(type="button", data-shape=shape.value, aria-pressed=shape.value === state.shape ? "true" : "false", class=shape.value === state.shape ? "active" : "")
                    svg(viewBox="0 0 24 24", aria-hidden="true")
                      path(d=shape.path)
                    span= shape.label

            section.section
              .section-title
                strong 尺寸
                span 画布高度与预设
              .field
                .field-label
                  span 画布高度
                  span.value#iconSizeValue= state.iconSize
                .range-row
                  input#iconSizeRange(type="range", min="1", max="2048", step="1", value=state.iconSize)
                  input#iconSizeInput(type="number", min="1", max="2048", step="1", value=state.iconSize)
              .preset-row#iconSizePresetRow
                button.preset-chip(type="button", data-size="24") 24
                button.preset-chip(type="button", data-size="30") 30
                button.preset-chip(type="button", data-size="36") 36
                button.preset-chip(type="button", data-size="45") 45
                button.preset-chip(type="button", data-size="54") 54
              .inline-note
                | 单击即可直接应用，适合常用输出尺寸。

            section.section
              .section-title
                strong 图像参数
                span 缩放与偏移
              .field
                .field-label
                  span 图片缩放
                  span.value#imageScaleValue= state.imageScale.toFixed(2)
                .range-row
                  input#imageScaleRange(type="range", min="0.01", max="10", step="0.01", value=state.imageScale)
                  input#imageScaleInput(type="number", min="0.01", max="10", step="0.01", value=state.imageScale)
              .field
                .field-label
                  span 垂直偏移
                  span.value#imageOffsetYValue= state.imageOffsetY
                .range-row
                  input#imageOffsetYRange(type="range", min="-50", max="50", step="1", value=state.imageOffsetY)
                  input#imageOffsetYInput(type="number", min="-50", max="50", step="1", value=state.imageOffsetY)

            section.section
              .section-title
                strong 边框
                span 宽度与拐角
              .field
                .field-label
                  span 边框宽度
                  span.value#borderWidthValue= state.borderWidth
                .range-row
                  input#borderWidthRange(type="range", min="0", max="20", step="1", value=state.borderWidth)
                  input#borderWidthInput(type="number", min="0", max="20", step="1", value=state.borderWidth)
              .field
                .field-label
                  span 拐角样式
                  span.value#lineJoinValue= ({ round: "圆角", miter: "斜接", bevel: "斜角" })[state.lineJoin] || state.lineJoin
                select#lineJoinSelect
                  option(value="round", selected=state.lineJoin === "round") 圆角
                  option(value="miter", selected=state.lineJoin === "miter") 斜接
                  option(value="bevel", selected=state.lineJoin === "bevel") 斜角

            section.section.full
              .section-title
                strong 轮廓增强
                span 多层描边与柔化
              .toggle-row
                .field-label
                  span 启用轮廓增强
                  span.value#contourEnhanceValue= state.contourEnhance ? "1" : "0"
                .switch#contourEnhanceSwitch(class=state.contourEnhance ? "on" : "")
              .grid-2
                .field
                  .field-label
                    span 外侧柔光
                    span.value#contourOuterGlowValue= state.contourOuterGlow
                  .range-row
                    input#contourOuterGlowRange(type="range", min="0", max="20", step="0.1", value=state.contourOuterGlow)
                    input#contourOuterGlowInput(type="number", min="0", max="20", step="0.1", value=state.contourOuterGlow)
                .field
                  .field-label
                    span 外扩描边
                    span.value#contourOuterWidthValue= state.contourOuterWidth
                  .range-row
                    input#contourOuterWidthRange(type="range", min="0", max="20", step="0.1", value=state.contourOuterWidth)
                    input#contourOuterWidthInput(type="number", min="0", max="20", step="0.1", value=state.contourOuterWidth)
                .field
                  .field-label
                    span 主轮廓描边
                    span.value#contourMainWidthValue= state.contourMainWidth
                  .range-row
                    input#contourMainWidthRange(type="range", min="0", max="20", step="0.1", value=state.contourMainWidth)
                    input#contourMainWidthInput(type="number", min="0", max="20", step="0.1", value=state.contourMainWidth)
                .field
                  .field-label
                    span 内侧柔化
                    span.value#contourInnerWidthValue= state.contourInnerWidth
                  .range-row
                    input#contourInnerWidthRange(type="range", min="0", max="20", step="0.1", value=state.contourInnerWidth)
                    input#contourInnerWidthInput(type="number", min="0", max="20", step="0.1", value=state.contourInnerWidth)
                .field
                  .field-label
                    span 尖角圆润度
                    span.value#contourCornerSoftnessValue= state.contourCornerSoftness
                  .range-row
                    input#contourCornerSoftnessRange(type="range", min="0", max="1", step="0.01", value=state.contourCornerSoftness)
                    input#contourCornerSoftnessInput(type="number", min="0", max="1", step="0.01", value=state.contourCornerSoftness)
              .inline-note
                | 默认值由 `ICON_PARAM_CONTOUR_ENHANCE`、`ICON_PARAM_CONTOUR_OUTER_GLOW`、`ICON_PARAM_CONTOUR_OUTER_WIDTH`、`ICON_PARAM_CONTOUR_MAIN_WIDTH`、`ICON_PARAM_CONTOUR_INNER_WIDTH`、`ICON_PARAM_CONTOUR_CORNER_SOFTNESS` 控制，查询串可覆盖。

            section.section
              .section-title
                strong 颜色
                span 描边与背景
              .field
                .color-row
                  input#borderColor(type="color", value=state.borderColor)
                  input#borderColorHex(type="text", value=state.borderColor)
                  span.value 描边
                .color-row
                  input#bgColor(type="color", value=state.bgColor)
                  input#bgColorHex(type="text", value=state.bgColor)
                  span.value 背景

            section.section
              .section-title
                strong 阴影
                span 开关与参数
              .toggle-row
                .field-label
                  span 启用阴影
                  span.value#enableShadowValue= state.enableShadow ? "1" : "0"
                .switch#enableShadowSwitch(class=state.enableShadow ? "on" : "")
              .field
                .field-label
                  span 阴影模糊
                  span.value#shadowBlurValue= state.shadowBlur
                .range-row
                  input#shadowBlurRange(type="range", min="0", max="50", step="1", value=state.shadowBlur)
                  input#shadowBlurInput(type="number", min="0", max="50", step="1", value=state.shadowBlur)
              .field
                .field-label
                  span 阴影偏移
                  span.value#shadowOffsetYValue= state.shadowOffsetY
                .range-row
                  input#shadowOffsetYRange(type="range", min="-20", max="20", step="1", value=state.shadowOffsetY)
                  input#shadowOffsetYInput(type="number", min="-20", max="20", step="1", value=state.shadowOffsetY)

            section.section
              .section-title
                strong 导出
                span 画布形状与对齐
              .toggle-row
                .field-label
                  span 正方形导出
                  span.value#exportSquareValue= state.exportSquare ? "1" : "0"
                .switch#exportSquareSwitch(class=state.exportSquare ? "on" : "")
              .field
                .field-label
                  span 对齐策略
                  span.value#exportStrategyValue= ({ center: "居中", bottom: "贴底" })[state.exportStrategy] || state.exportStrategy
                select#exportStrategySelect
                  option(value="center", selected=state.exportStrategy === "center") 居中
                  option(value="bottom", selected=state.exportStrategy === "bottom") 贴底

            section.section.full
              .section-title
                strong 抗锯齿
                span 超采样与缩小策略
              .grid-2
                .field
                  .field-label
                    span 超采样倍率
                    span.value#antiAliasScaleValue= state.antiAliasScale
                  select#antiAliasScaleSelect
                    option(value="1", selected=state.antiAliasScale === 1) 1x
                    option(value="2", selected=state.antiAliasScale === 2) 2x
                    option(value="4", selected=state.antiAliasScale === 4) 4x
                .field
                  .field-label
                    span 缩小方式
                    span.value#resizeStrategyValue= ({ "smooth-high": "平滑高质量", pixelated: "像素风", "step-down": "逐级缩小", "sharp-lanczos3": "Sharp Lanczos3" })[state.resizeStrategy] || state.resizeStrategy
                  select#resizeStrategySelect
                    option(value="smooth-high", selected=state.resizeStrategy === "smooth-high") 平滑高质量
                    option(value="pixelated", selected=state.resizeStrategy === "pixelated") 像素风
                    option(value="step-down", selected=state.resizeStrategy === "step-down") 逐级缩小
                    option(value="sharp-lanczos3", selected=state.resizeStrategy === "sharp-lanczos3") Sharp Lanczos3
              .inline-note
                | `antiAliasScale` 控制超采样倍率，`resizeStrategy` 控制缩小方式。预览保持 `1x`，导出和复制请求按当前选择生效。

            section.section.full
              .section-title
                strong 请求文本
                span 当前配置生成的请求
              .request-box
                textarea#requestText(readonly)
                .request-actions
                  button#copyRequestBtn2.primary-btn(type="button") 复制请求
                  button#copyQueryBtn2.ghost-btn(type="button") 复制查询串
                .inline-note#requestHint
                  | 本地图片优先生成 multipart 请求；否则复制 `GET /icon?...`。

        section.preview
          .preview-head
            h2 预览
            .preview-meta
              span#previewSize 0 × 0
              |  · 
              span#previewMode GET
          .preview-body
            .preview-stage
              img#previewImage(alt="服务端预览")
            .preview-status
              .left
                strong#previewStatus 加载中
                |  · 
                span#previewTip 等待你调整参数
              .right
                span#previewInfo -

    script.
      window.__ICON_PAGE__ = !{pageDataJson};

    script.
      (() => {
        const config = window.__ICON_PAGE__;
        const initialState = config.state;
        const apiBaseUrl = config.apiBaseUrl;
        const apiIconUrl = `${apiBaseUrl}${config.apiIconPath}`;
        const apiInfoUrl = `${apiBaseUrl}${config.apiInfoPath}`;
        const apiImageBedUploadUrl = config.apiImageBedUploadUrl || "";
        const imageEnableBase64 = !!config.imageEnableBase64;
        const shapeLabels = Object.fromEntries((config.shapeOptions || []).map((item) => [item.value, item.label]));
        const lineJoinLabels = {
          round: "圆角",
          miter: "斜接",
          bevel: "斜角",
        };
        const exportStrategyLabels = {
          center: "居中",
          bottom: "贴底",
        };
        const resizeStrategyLabels = {
          "smooth-high": "平滑高质量",
          pixelated: "像素风",
          "step-down": "逐级缩小",
          "sharp-lanczos3": "Sharp Lanczos3",
        };
        const state = {
          ...initialState,
          imageMode: "get",
          file: null,
          fileName: "",
          filePreviewUrl: "",
        };

        const els = {
          sourceCard: document.getElementById("imageSourceCard"),
          imageModeSelect: document.getElementById("imageModeSelect"),
          imageUpload: document.getElementById("imageUpload"),
          imageUploadButton: document.getElementById("imageUploadButton"),
          sourcePreview: document.getElementById("sourcePreview"),
          uploadHint: document.getElementById("uploadHint"),
          image: document.getElementById("image"),
          imageState: document.getElementById("imageState"),
          modeState: document.getElementById("modeState"),
          requestMode: document.getElementById("requestMode"),
          requestModeInput: document.getElementById("requestModeInput"),
          fileName: document.getElementById("fileName"),
          imageNote: document.getElementById("imageNote"),
          shapeGrid: document.getElementById("shapeGrid"),
          iconSizeRange: document.getElementById("iconSizeRange"),
          iconSizeInput: document.getElementById("iconSizeInput"),
          iconSizeValue: document.getElementById("iconSizeValue"),
          imageScaleRange: document.getElementById("imageScaleRange"),
          imageScaleInput: document.getElementById("imageScaleInput"),
          imageScaleValue: document.getElementById("imageScaleValue"),
          imageOffsetYRange: document.getElementById("imageOffsetYRange"),
          imageOffsetYInput: document.getElementById("imageOffsetYInput"),
          imageOffsetYValue: document.getElementById("imageOffsetYValue"),
          borderWidthRange: document.getElementById("borderWidthRange"),
          borderWidthInput: document.getElementById("borderWidthInput"),
          borderWidthValue: document.getElementById("borderWidthValue"),
          lineJoinSelect: document.getElementById("lineJoinSelect"),
          lineJoinValue: document.getElementById("lineJoinValue"),
          contourEnhanceSwitch: document.getElementById("contourEnhanceSwitch"),
          contourEnhanceValue: document.getElementById("contourEnhanceValue"),
          contourOuterGlowRange: document.getElementById("contourOuterGlowRange"),
          contourOuterGlowInput: document.getElementById("contourOuterGlowInput"),
          contourOuterGlowValue: document.getElementById("contourOuterGlowValue"),
          contourOuterWidthRange: document.getElementById("contourOuterWidthRange"),
          contourOuterWidthInput: document.getElementById("contourOuterWidthInput"),
          contourOuterWidthValue: document.getElementById("contourOuterWidthValue"),
          contourMainWidthRange: document.getElementById("contourMainWidthRange"),
          contourMainWidthInput: document.getElementById("contourMainWidthInput"),
          contourMainWidthValue: document.getElementById("contourMainWidthValue"),
          contourInnerWidthRange: document.getElementById("contourInnerWidthRange"),
          contourInnerWidthInput: document.getElementById("contourInnerWidthInput"),
          contourInnerWidthValue: document.getElementById("contourInnerWidthValue"),
          contourCornerSoftnessRange: document.getElementById("contourCornerSoftnessRange"),
          contourCornerSoftnessInput: document.getElementById("contourCornerSoftnessInput"),
          contourCornerSoftnessValue: document.getElementById("contourCornerSoftnessValue"),
          borderColor: document.getElementById("borderColor"),
          borderColorHex: document.getElementById("borderColorHex"),
          bgColor: document.getElementById("bgColor"),
          bgColorHex: document.getElementById("bgColorHex"),
          enableShadowSwitch: document.getElementById("enableShadowSwitch"),
          enableShadowValue: document.getElementById("enableShadowValue"),
          shadowBlurRange: document.getElementById("shadowBlurRange"),
          shadowBlurInput: document.getElementById("shadowBlurInput"),
          shadowBlurValue: document.getElementById("shadowBlurValue"),
          shadowOffsetYRange: document.getElementById("shadowOffsetYRange"),
          shadowOffsetYInput: document.getElementById("shadowOffsetYInput"),
          shadowOffsetYValue: document.getElementById("shadowOffsetYValue"),
          antiAliasScaleSelect: document.getElementById("antiAliasScaleSelect"),
          antiAliasScaleValue: document.getElementById("antiAliasScaleValue"),
          resizeStrategySelect: document.getElementById("resizeStrategySelect"),
          resizeStrategyValue: document.getElementById("resizeStrategyValue"),
          exportSquareSwitch: document.getElementById("exportSquareSwitch"),
          exportSquareValue: document.getElementById("exportSquareValue"),
          exportStrategySelect: document.getElementById("exportStrategySelect"),
          exportStrategyValue: document.getElementById("exportStrategyValue"),
          requestText: document.getElementById("requestText"),
          requestHint: document.getElementById("requestHint"),
          previewImage: document.getElementById("previewImage"),
          previewStatus: document.getElementById("previewStatus"),
          previewTip: document.getElementById("previewTip"),
          previewInfo: document.getElementById("previewInfo"),
          previewSize: document.getElementById("previewSize"),
          previewMode: document.getElementById("previewMode"),
          copyRequestBtn: document.getElementById("copyRequestBtn"),
          copyRequestBtn2: document.getElementById("copyRequestBtn2"),
          copyQueryBtn: document.getElementById("copyQueryBtn"),
          copyQueryBtn2: document.getElementById("copyQueryBtn2"),
        };

        let previewObjectUrl = "";
        let previewTimer = 0;
        let previewToken = 0;

        const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
        const round2 = (value) => Number.parseFloat(Number(value).toFixed(2));
        const describeImageState = (image) => {
          if (!image) return "-";
          if (image.startsWith("data:image/")) return "base64";
          if (/^https?:\/\//i.test(image)) return "URL";
          return "相对路径";
        };

        const getUploadDisabledReason = () => {
          if (state.imageMode === "get" && !apiImageBedUploadUrl) {
            return "当前未启动本地图床服务，GET 模式下无法上传文件";
          }
          return "";
        };

        const isUploadEnabled = () => {
          return state.imageMode === "post" || !!apiImageBedUploadUrl;
        };

        const revokeFilePreview = () => {
          if (state.filePreviewUrl) {
            URL.revokeObjectURL(state.filePreviewUrl);
            state.filePreviewUrl = "";
          }
        };

        const clearUploadState = () => {
          revokeFilePreview();
          state.file = null;
          state.fileName = "";
          if (els.imageUpload) {
            els.imageUpload.value = "";
          }
        };

        const setMode = (mode) => {
          if (mode === state.imageMode) return;
          state.imageMode = mode;
          state.image = "";
          clearUploadState();
          refreshAll();
        };

        const uploadFileToBed = async (file) => {
          const formData = new FormData();
          formData.set("image", file, file.name);
          const res = await fetch(apiImageBedUploadUrl, {
            method: "POST",
            body: formData,
          });
          if (!res.ok) {
            throw new Error(`imgbed ${res.status}`);
          }
          const payload = await res.json();
          if (!payload || !payload.url) {
            throw new Error("imgbed 响应缺少 url");
          }
          return payload.url;
        };

        const setPreviewFromFile = async (file) => {
          if (!file) return;
          revokeFilePreview();
          state.fileName = file.name;
          state.filePreviewUrl = URL.createObjectURL(file);

          if (state.imageMode === "post") {
            state.file = file;
            state.image = "";
          } else {
            state.file = null;
            state.image = await uploadFileToBed(file);
          }

          refreshAll();
        };

        const formatNumber = (value) => {
          const normalized = Number(value);
          return Number.isInteger(normalized) ? String(normalized) : String(round2(normalized));
        };

        const syncControlValues = () => {
          const uploadEnabled = isUploadEnabled();
          const uploadDisabledReason = getUploadDisabledReason();
          const isPost = state.imageMode === "post";
          const hasPreview = !!state.filePreviewUrl;

          els.imageModeSelect.value = state.imageMode;
          els.modeState.textContent = state.imageMode.toUpperCase();
          els.requestMode.textContent = state.imageMode.toUpperCase();
          els.requestModeInput.value = `${state.imageMode.toUpperCase()} /icon`;
          els.image.readOnly = isPost;
          els.image.value = isPost ? (state.fileName ? `file:${state.fileName}` : "") : (state.image || "");
          els.image.placeholder = isPost
            ? "选择文件后显示 file:xxx.png"
            : imageEnableBase64
              ? "https://example.com/icon.png / /assets/icon.png / data:image/png;base64,..."
              : "https://example.com/icon.png / /assets/icon.png";
          els.imageState.textContent = isPost
            ? (state.fileName ? "file" : "-")
            : describeImageState(state.image);
          els.fileName.textContent = state.fileName
            ? `file:${state.fileName}`
            : (uploadEnabled ? "未选择文件" : "当前无法输入图像");
          els.uploadHint.textContent = uploadDisabledReason || (isPost
            ? "POST 模式下选择文件后会使用 multipart 文件上传。"
            : (imageEnableBase64
              ? "GET 模式可直接输入 URL / 相对路径；选文件会先上传到本地图床并写入短 URL，也可粘贴 `data:`。"
              : "GET 模式可直接输入 URL / 相对路径；选文件会先上传到本地图床并写入短 URL。"));
          els.imageUpload.disabled = !uploadEnabled;
          els.imageUploadButton.classList.toggle("disabled", !uploadEnabled);
          els.imageUploadButton.setAttribute("aria-disabled", uploadEnabled ? "false" : "true");
          els.sourceCard.classList.toggle("disabled", !uploadEnabled);
          els.sourceCard.setAttribute("aria-disabled", uploadEnabled ? "false" : "true");
          els.sourceCard.title = uploadDisabledReason || "拖放整个卡片即可选择文件";
          els.sourcePreview.classList.toggle("visible", hasPreview);
          els.sourcePreview.src = hasPreview ? state.filePreviewUrl : "";
          els.iconSizeValue.textContent = String(state.iconSize);
          els.iconSizeRange.value = state.iconSize;
          els.iconSizeInput.value = state.iconSize;
          els.imageScaleValue.textContent = Number(state.imageScale).toFixed(2);
          els.imageScaleRange.value = state.imageScale;
          els.imageScaleInput.value = state.imageScale;
          els.imageOffsetYValue.textContent = String(state.imageOffsetY);
          els.imageOffsetYRange.value = state.imageOffsetY;
          els.imageOffsetYInput.value = state.imageOffsetY;
          els.borderWidthValue.textContent = String(state.borderWidth);
          els.borderWidthRange.value = state.borderWidth;
          els.borderWidthInput.value = state.borderWidth;
          els.lineJoinSelect.value = state.lineJoin;
          els.lineJoinValue.textContent = lineJoinLabels[state.lineJoin] || state.lineJoin;
          els.contourEnhanceSwitch.classList.toggle("on", !!state.contourEnhance);
          els.contourEnhanceValue.textContent = state.contourEnhance ? "1" : "0";
          els.contourOuterGlowValue.textContent = formatNumber(state.contourOuterGlow);
          els.contourOuterGlowRange.value = state.contourOuterGlow;
          els.contourOuterGlowInput.value = state.contourOuterGlow;
          els.contourOuterWidthValue.textContent = formatNumber(state.contourOuterWidth);
          els.contourOuterWidthRange.value = state.contourOuterWidth;
          els.contourOuterWidthInput.value = state.contourOuterWidth;
          els.contourMainWidthValue.textContent = formatNumber(state.contourMainWidth);
          els.contourMainWidthRange.value = state.contourMainWidth;
          els.contourMainWidthInput.value = state.contourMainWidth;
          els.contourInnerWidthValue.textContent = formatNumber(state.contourInnerWidth);
          els.contourInnerWidthRange.value = state.contourInnerWidth;
          els.contourInnerWidthInput.value = state.contourInnerWidth;
          els.contourCornerSoftnessValue.textContent = formatNumber(state.contourCornerSoftness);
          els.contourCornerSoftnessRange.value = state.contourCornerSoftness;
          els.contourCornerSoftnessInput.value = state.contourCornerSoftness;
          els.borderColor.value = state.borderColor;
          els.borderColorHex.value = state.borderColor;
          els.bgColor.value = state.bgColor;
          els.bgColorHex.value = state.bgColor;
          els.enableShadowSwitch.classList.toggle("on", !!state.enableShadow);
          els.enableShadowValue.textContent = state.enableShadow ? "1" : "0";
          els.shadowBlurValue.textContent = String(state.shadowBlur);
          els.shadowBlurRange.value = state.shadowBlur;
          els.shadowBlurInput.value = state.shadowBlur;
          els.shadowOffsetYValue.textContent = String(state.shadowOffsetY);
          els.shadowOffsetYRange.value = state.shadowOffsetY;
          els.shadowOffsetYInput.value = state.shadowOffsetY;
          els.antiAliasScaleValue.textContent = String(state.antiAliasScale);
          els.antiAliasScaleSelect.value = String(state.antiAliasScale);
          els.resizeStrategyValue.textContent = resizeStrategyLabels[state.resizeStrategy] || state.resizeStrategy;
          els.resizeStrategySelect.value = state.resizeStrategy;
          els.exportSquareSwitch.classList.toggle("on", !!state.exportSquare);
          els.exportSquareValue.textContent = state.exportSquare ? "1" : "0";
          els.exportStrategySelect.value = state.exportStrategy;
          els.exportStrategyValue.textContent = exportStrategyLabels[state.exportStrategy] || state.exportStrategy;
          document.querySelectorAll("#iconSizePresetRow .preset-chip").forEach((button) => {
            const active = Number(button.dataset.size) === state.iconSize;
            button.classList.toggle("active", active);
          });

          document.querySelectorAll(".shape-card").forEach((card) => {
            const active = card.dataset.shape === state.shape;
            card.classList.toggle("active", active);
            card.setAttribute("aria-pressed", active ? "true" : "false");
          });

          els.imageNote.textContent = state.imageMode === "post"
            ? "POST 模式下图片通过文件上传；若切回 GET，会清空文件状态。"
            : (apiImageBedUploadUrl
              ? "GET 模式支持 URL / 相对路径；选文件会先上传到本地图床并把短 URL 写入 `image`。"
              : "GET 模式支持 URL / 相对路径；需先启动本地图床服务才可选择文件上传。");
        };

        const buildQueryParams = () => {
          const params = new URLSearchParams();
          params.set("shape", state.shape);
          params.set("iconSize", String(state.iconSize));
          params.set("imageScale", String(state.imageScale));
          params.set("imageOffsetY", String(state.imageOffsetY));
          params.set("borderWidth", String(state.borderWidth));
          params.set("lineJoin", state.lineJoin);
          params.set("borderColor", state.borderColor);
          params.set("bgColor", state.bgColor);
          params.set("contourEnhance", state.contourEnhance ? "1" : "0");
          params.set("contourOuterGlow", String(state.contourOuterGlow));
          params.set("contourOuterWidth", String(state.contourOuterWidth));
          params.set("contourMainWidth", String(state.contourMainWidth));
          params.set("contourInnerWidth", String(state.contourInnerWidth));
          params.set("contourCornerSoftness", String(state.contourCornerSoftness));
          params.set("enableShadow", state.enableShadow ? "1" : "0");
          params.set("shadowBlur", String(state.shadowBlur));
          params.set("shadowOffsetY", String(state.shadowOffsetY));
          params.set("exportSquare", state.exportSquare ? "1" : "0");
          params.set("exportStrategy", state.exportStrategy);
          params.set("antiAliasScale", String(state.antiAliasScale));
          params.set("resizeStrategy", state.resizeStrategy);
          if (state.imageMode === "get" && state.image) {
            params.set("image", state.image);
          }
          return params;
        };

        const buildPreviewParams = () => {
          const params = buildQueryParams();
          params.set("antiAliasScale", "1");
          params.set("resizeStrategy", "smooth-high");
          return params;
        };

        const buildRequestText = () => {
          if (state.imageMode === "post") {
            const lines = [
              `curl -X POST "${apiIconUrl}" \\`,
              `  -F "shape=${state.shape}" \\`,
              `  -F "iconSize=${state.iconSize}" \\`,
              `  -F "imageScale=${state.imageScale}" \\`,
              `  -F "imageOffsetY=${state.imageOffsetY}" \\`,
              `  -F "borderWidth=${state.borderWidth}" \\`,
              `  -F "lineJoin=${state.lineJoin}" \\`,
              `  -F "borderColor=${state.borderColor}" \\`,
              `  -F "bgColor=${state.bgColor}" \\`,
              `  -F "contourEnhance=${state.contourEnhance ? 1 : 0}" \\`,
              `  -F "contourOuterGlow=${state.contourOuterGlow}" \\`,
              `  -F "contourOuterWidth=${state.contourOuterWidth}" \\`,
              `  -F "contourMainWidth=${state.contourMainWidth}" \\`,
              `  -F "contourInnerWidth=${state.contourInnerWidth}" \\`,
              `  -F "contourCornerSoftness=${state.contourCornerSoftness}" \\`,
              `  -F "enableShadow=${state.enableShadow ? 1 : 0}" \\`,
              `  -F "shadowBlur=${state.shadowBlur}" \\`,
              `  -F "shadowOffsetY=${state.shadowOffsetY}" \\`,
              `  -F "exportSquare=${state.exportSquare ? 1 : 0}" \\`,
              `  -F "exportStrategy=${state.exportStrategy}" \\`,
              `  -F "antiAliasScale=${state.antiAliasScale}" \\`,
              `  -F "resizeStrategy=${state.resizeStrategy}" \\`,
            ];
            lines.push(
              state.fileName
                ? `  -F "image=@${state.fileName}" \\`
                : `  -F "image=@/path/to/your/image.png" \\`
            );
            lines.push(`  -o output.png`);
            return lines.join("\n");
          }

          return `${apiIconUrl}?${buildQueryParams().toString()}`;
        };

        const buildPreviewRequest = () => {
          const query = buildPreviewParams().toString();
          return `${apiIconUrl}?${query}&_=${Date.now()}`;
        };

        const shouldUsePostPreview = () => {
          return state.imageMode === "post";
        };

        const copyText = async (text) => {
          if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
            return;
          }
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.position = "fixed";
          ta.style.inset = "0";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          ta.remove();
        };

        const updateRequestBox = () => {
          els.requestText.value = buildRequestText();
          els.requestHint.textContent = state.imageMode === "post"
            ? (state.fileName
              ? "POST 模式使用 file 上传；复制内容为 multipart `curl` 请求。"
              : "POST 模式需要先选择文件；复制文本会给出文件上传模板。")
            : (imageEnableBase64
              ? "GET 模式复制查询串；选文件会先上传到本地图床并写入短 URL，也可以直接粘贴 `data:`。"
              : "GET 模式复制查询串；选文件会先上传到本地图床并写入短 URL。");
          els.previewMode.textContent = state.imageMode.toUpperCase();
        };

        const updatePreviewInfo = async () => {
          try {
            const params = buildQueryParams();
            const infoRes = await fetch(`${apiInfoUrl}?${params.toString()}`, {
              headers: { Accept: "application/json" },
            });
            if (!infoRes.ok) {
              throw new Error(`info ${infoRes.status}`);
            }
            const info = await infoRes.json();
            els.previewSize.textContent = `${info.width} × ${info.height}`;
            const contourLabel = info.state.contourEnhance
              ? `增强(外晕 ${formatNumber(info.state.contourOuterGlow)} / 外扩 ${formatNumber(info.state.contourOuterWidth)} / 主描 ${formatNumber(info.state.contourMainWidth)} / 内柔 ${formatNumber(info.state.contourInnerWidth)} / 圆润 ${formatNumber(info.state.contourCornerSoftness)})`
              : "关闭";
            els.previewInfo.textContent = `形状=${shapeLabels[info.state.shape] || info.state.shape}，轮廓=${contourLabel}，超采样=${info.state.antiAliasScale}x，缩小=${resizeStrategyLabels[info.state.resizeStrategy] || info.state.resizeStrategy}，渲染=${info.renderWidth} × ${info.renderHeight}`;
          } catch (error) {
            els.previewSize.textContent = "0 × 0";
            els.previewInfo.textContent = `info 失败: ${error.message}`;
          }
        };

        const updatePreviewImage = async () => {
          const token = ++previewToken;
          els.previewStatus.textContent = "加载中";
          const usePost = shouldUsePostPreview();
          els.previewTip.textContent = usePost ? "POST /icon" : "GET /icon";

          if (previewObjectUrl) {
            URL.revokeObjectURL(previewObjectUrl);
            previewObjectUrl = "";
          }

          try {
            if (usePost) {
              const formData = new FormData();
              if (state.file) {
                formData.set("image", state.file, state.fileName || state.file.name);
              }
              for (const [key, value] of buildPreviewParams().entries()) {
                formData.set(key, value);
              }
              const res = await fetch(apiIconUrl, {
                method: "POST",
                body: formData,
              });
              if (!res.ok) {
                throw new Error(`icon ${res.status}`);
              }
              const blob = await res.blob();
              if (token !== previewToken) return;
              if (previewObjectUrl) {
                URL.revokeObjectURL(previewObjectUrl);
              }
              previewObjectUrl = URL.createObjectURL(blob);
              els.previewImage.src = previewObjectUrl;
            } else {
              els.previewImage.src = buildPreviewRequest();
            }
            if (token !== previewToken) return;
            els.previewStatus.textContent = "已更新";
            els.previewTip.textContent = usePost ? "POST /icon" : "GET /icon";
          } catch (error) {
            if (token !== previewToken) return;
            els.previewStatus.textContent = "预览失败";
            els.previewTip.textContent = error.message;
          }
        };

        const refreshAll = () => {
          syncControlValues();
          updateRequestBox();
          window.clearTimeout(previewTimer);
          previewTimer = window.setTimeout(() => {
            updatePreviewInfo();
            updatePreviewImage();
          }, 120);
        };

        const setState = (patch) => {
          Object.assign(state, patch);
          refreshAll();
        };

        document.getElementById("shapeGrid").addEventListener("click", (event) => {
          const card = event.target.closest(".shape-card");
          if (!card) return;
          setState({ shape: card.dataset.shape });
        });

        const bindRange = (rangeEl, inputEl, key, mapValue = (value) => value) => {
          const handler = (rawValue) => {
            const value = mapValue(rawValue);
            setState({ [key]: value });
          };
          rangeEl.addEventListener("input", (event) => handler(event.target.value));
          inputEl.addEventListener("input", (event) => handler(event.target.value));
        };

        bindRange(els.iconSizeRange, els.iconSizeInput, "iconSize", (value) => clamp(parseInt(value || "128", 10), 1, 2048));
        bindRange(els.imageScaleRange, els.imageScaleInput, "imageScale", (value) => clamp(Number.parseFloat(value || "1"), 0.01, 10));
        bindRange(els.imageOffsetYRange, els.imageOffsetYInput, "imageOffsetY", (value) => clamp(parseInt(value || "0", 10), -50, 50));
        bindRange(els.borderWidthRange, els.borderWidthInput, "borderWidth", (value) => clamp(parseInt(value || "0", 10), 0, 20));
        bindRange(els.contourOuterGlowRange, els.contourOuterGlowInput, "contourOuterGlow", (value) => clamp(Number.parseFloat(value || "0"), 0, 20));
        bindRange(els.contourOuterWidthRange, els.contourOuterWidthInput, "contourOuterWidth", (value) => clamp(Number.parseFloat(value || "0"), 0, 20));
        bindRange(els.contourMainWidthRange, els.contourMainWidthInput, "contourMainWidth", (value) => clamp(Number.parseFloat(value || "0"), 0, 20));
        bindRange(els.contourInnerWidthRange, els.contourInnerWidthInput, "contourInnerWidth", (value) => clamp(Number.parseFloat(value || "0"), 0, 20));
        bindRange(els.contourCornerSoftnessRange, els.contourCornerSoftnessInput, "contourCornerSoftness", (value) => clamp(Number.parseFloat(value || "0"), 0, 1));
        bindRange(els.shadowBlurRange, els.shadowBlurInput, "shadowBlur", (value) => clamp(parseInt(value || "0", 10), 0, 50));
        bindRange(els.shadowOffsetYRange, els.shadowOffsetYInput, "shadowOffsetY", (value) => clamp(parseInt(value || "0", 10), -20, 20));

        els.lineJoinSelect.addEventListener("change", (event) => setState({ lineJoin: event.target.value }));
        els.borderColor.addEventListener("input", (event) => setState({ borderColor: event.target.value }));
        els.borderColorHex.addEventListener("input", (event) => setState({ borderColor: event.target.value.trim() }));
        els.bgColor.addEventListener("input", (event) => setState({ bgColor: event.target.value }));
        els.bgColorHex.addEventListener("input", (event) => setState({ bgColor: event.target.value.trim() }));
        els.exportStrategySelect.addEventListener("change", (event) => setState({ exportStrategy: event.target.value }));
        els.antiAliasScaleSelect.addEventListener("change", (event) => setState({ antiAliasScale: clamp(parseInt(event.target.value || "1", 10), 1, 4) }));
        els.resizeStrategySelect.addEventListener("change", (event) => setState({ resizeStrategy: event.target.value }));
        els.imageModeSelect.addEventListener("change", (event) => setMode(event.target.value === "post" ? "post" : "get"));
        document.getElementById("iconSizePresetRow").addEventListener("click", (event) => {
          const button = event.target.closest(".preset-chip");
          if (!button) return;
          setState({ iconSize: clamp(parseInt(button.dataset.size || "128", 10), 1, 2048) });
        });

        els.enableShadowSwitch.addEventListener("click", () => setState({ enableShadow: !state.enableShadow }));
        els.contourEnhanceSwitch.addEventListener("click", () => setState({ contourEnhance: !state.contourEnhance }));
        els.exportSquareSwitch.addEventListener("click", () => setState({ exportSquare: !state.exportSquare }));

        els.image.addEventListener("input", (event) => {
          if (state.imageMode === "post") return;
          const nextImage = event.target.value.trim();
          setState({ image: nextImage });
        });

        const handleFile = async (file) => {
          if (!file || !isUploadEnabled()) return;
          await setPreviewFromFile(file);
        };

        els.imageUpload.addEventListener("change", async (event) => {
          const file = event.target.files && event.target.files[0];
          try {
            await handleFile(file);
          } catch (error) {
            els.previewStatus.textContent = "图床失败";
            els.previewTip.textContent = error.message;
          }
          event.target.value = "";
        });

        els.sourceCard.addEventListener("dragover", (event) => {
          event.preventDefault();
          if (!isUploadEnabled()) return;
          els.sourceCard.classList.add("drag");
        });

        els.sourceCard.addEventListener("dragleave", () => {
          els.sourceCard.classList.remove("drag");
        });

        els.sourceCard.addEventListener("drop", async (event) => {
          event.preventDefault();
          if (!isUploadEnabled()) return;
          els.sourceCard.classList.remove("drag");
          const file = event.dataTransfer.files && event.dataTransfer.files[0];
          try {
            await handleFile(file);
          } catch (error) {
            els.previewStatus.textContent = "图床失败";
            els.previewTip.textContent = error.message;
          }
        });

        const copyCurrentRequest = async () => {
          await copyText(els.requestText.value);
          els.previewStatus.textContent = "已复制";
          els.previewTip.textContent = "请求文本已复制到剪贴板";
        };

        const copyCurrentQuery = async () => {
          await copyText(buildQueryParams().toString());
          els.previewStatus.textContent = "已复制";
          els.previewTip.textContent = "查询串已复制到剪贴板";
        };

        els.copyRequestBtn.addEventListener("click", copyCurrentRequest);
        els.copyRequestBtn2.addEventListener("click", copyCurrentRequest);
        els.copyQueryBtn.addEventListener("click", copyCurrentQuery);
        els.copyQueryBtn2.addEventListener("click", copyCurrentQuery);

        syncControlValues();
        refreshAll();
      })();
