{
  "name": "icon-combinder",
  "version": "1.0.3",
  "description": "Library for composing wrapper icons, with a local test server and browser UMD entry",
  "main": "./index.js",
  "license": "MIT",
  "files": [
    "index.js",
    "index.mjs",
    "server.js",
    "browser.js",
    "imgbed-server.js",
    "core/",
    "views/",
    "scripts/"
  ],
  "exports": {
    ".": {
      "browser": "./browser.mjs",
      "require": "./index.js",
      "import": "./index.mjs"
    },
    "./browser.js": "./browser.js",
    "./browser.mjs": "./browser.mjs",
    "./server.js": "./server.js",
    "./imgbed-server.js": "./imgbed-server.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node scripts/dev.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "node --test __test__/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ccwq/icon-conbinder.git"
  },
  "homepage": "https://ccwq.github.io/icon-conbinder/",
  "bugs": {
    "url": "https://github.com/ccwq/icon-conbinder/issues"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.68",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "dotenv": "^16.4.5",
    "multer": "^1.4.5-lts.1",
    "pug": "^3.0.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  }
}
