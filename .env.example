# 服务监听端口。范围：1-65535。默认 3000。
PORT=3000

# 是否开启全局 CORS。候选值：0 / 1。默认 0。
ENABLE_CORS=0

# 请求参数默认值。运行时优先读取这些 ICON_PARAM_*，不需要改代码。
# 形状。候选值：pin / circle / square / squircle / hexagon。默认 pin。
ICON_PARAM_SHAPE=pin
# 画布高度（px）。范围：1-2048。默认 128。
ICON_PARAM_ICON_SIZE=128
# 内部图片缩放。范围：0.01-10。默认 1.0。
ICON_PARAM_IMAGE_SCALE=1.0
# 内部图片垂直偏移。范围：-50 到 50。默认 0。
ICON_PARAM_IMAGE_OFFSET_Y=0
# 边框宽度。范围：0-20。默认 4。
ICON_PARAM_BORDER_WIDTH=4
# 边框拐角样式。候选值：round / miter / bevel。默认 round。
ICON_PARAM_LINE_JOIN=round
# 边框颜色。格式：#rrggbb。默认 #ef4444。
ICON_PARAM_BORDER_COLOR=#ef4444
# 背景/填充颜色。格式：#rrggbb。默认 #ffffff。
ICON_PARAM_BG_COLOR=#ffffff
# 是否启用阴影。候选值：0 / 1。默认 1。
ICON_PARAM_ENABLE_SHADOW=1
# 阴影模糊度。范围：0-50。默认 10。
ICON_PARAM_SHADOW_BLUR=10
# 阴影垂直偏移。范围：-20 到 20。默认 5。
ICON_PARAM_SHADOW_OFFSET_Y=5
# 是否导出正方形画布。候选值：0 / 1。默认 1。
ICON_PARAM_EXPORT_SQUARE=1
# 对齐策略。候选值：center / bottom。默认 center。
ICON_PARAM_EXPORT_STRATEGY=center
# 超采样倍率。候选值：1 / 2 / 4。默认 1。
ICON_PARAM_ANTI_ALIAS_SCALE=1
# 缩小策略。候选值：smooth-high / pixelated / step-down / sharp-lanczos3。默认 smooth-high。
ICON_PARAM_RESIZE_STRATEGY=smooth-high

# image 解析规则。
# 远程图片基础前缀。可选，留空表示不合并相对路径。默认空。
IMAGE_URL_PREFIX=
# 是否强制最终解析后的 URL 必须命中 IMAGE_URL_PREFIX。候选值：0 / 1。默认 0。
IMAGE_URL_PREFIX_ONLY=0
# 是否允许 data:image/*;base64,...。候选值：0 / 1。默认 0。
IMAGE_ENABLE_BASE64=0

# 开发模式下的独立图床服务地址。npm run dev 默认注入 http://127.0.0.1:3001
IMG_BED_BASE_URL=
